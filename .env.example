# ─────────────────────────────────────────────────────────────────────────────
# SmileCare Dental Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file and rename it to ".env"  (never commit .env to GitHub)
#   2. Fill in each value below
#   3. On Railway: add these same keys under your service → Variables tab
# ─────────────────────────────────────────────────────────────────────────────

# ── DATABASE ─────────────────────────────────────────────────────────────────
# Paste your Railway PostgreSQL connection string here.
# On Railway: go to your PostgreSQL service → Connect → copy "DATABASE_URL"
# It looks like: postgresql://postgres:password@host.railway.internal:5432/railway
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ── SERVER ───────────────────────────────────────────────────────────────────
# Port to run the server on. Railway sets this automatically — leave as 3001 for local.
PORT=3001

# ── FRONTEND DOMAIN ──────────────────────────────────────────────────────────
# The URL of your React frontend on Railway (CORS will allow requests from here).
FRONTEND_URL=https://dental-practice-frontend-production.up.railway.app

# ── WHATSAPP API (Twilio) ─────────────────────────────────────────────────────
# Sign up at https://www.twilio.com → get a WhatsApp-enabled number
# Fill these in when you are ready to send real WhatsApp messages.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── WHATSAPP API (Infobip — alternative to Twilio) ───────────────────────────
# Sign up at https://www.infobip.com if you prefer Infobip
INFOBIP_API_KEY=your_infobip_api_key_here
INFOBIP_BASE_URL=https://XXXXX.api.infobip.com
INFOBIP_WHATSAPP_NUMBER=your_infobip_whatsapp_number
